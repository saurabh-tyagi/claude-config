{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "awsAuthRefresh": "aws sso login --profile claude-bedrock",
  "env": {
    "CLAUDE_CODE_USE_BEDROCK": "1",
    "AWS_PROFILE": "claude-bedrock",
    "AWS_REGION": "eu-west-1",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "eu.anthropic.claude-opus-4-7[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "eu.anthropic.claude-sonnet-4-6[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "eu.anthropic.claude-haiku-4-5-20251001"
  },
  "model": "opusplan",
  "effortLevel": "high",
  "theme": "auto",
  "model_aliases": {
    "plan": "opusplan",
    "review": "opus",
    "heavy": "opus",
    "fast": "sonnet"
  },
  "model_options": {
    "thinking": {
      "type": "adaptive",
      "budget_tokens": 24000
    },
    "max_tokens": 128000
  },
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(sed:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(make test:*)",
      "Bash(make lint:*)",
      "Bash(make validate:*)",
      "Bash(make check:*)",
      "Bash(pytest:*)",
      "Bash(python3 -m pytest:*)",
      "Bash(uv run pytest:*)",
      "Bash(ruff check:*)",
      "Bash(uv run ruff:*)",
      "Bash(ruff format:*)",
      "Bash(black:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(rmdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(truncate:*)",
      "Bash(shred:*)",
      "Bash(dd:*)",
      "Bash(sed -i:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
