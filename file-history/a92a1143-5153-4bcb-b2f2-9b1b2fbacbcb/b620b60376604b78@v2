def test_s3_writer_sorts_entries_by_timestamp_ascending():
    s3 = _make_stub_s3_writer()
    writer = S3AuditLogWriter(
        bucket="bucket", prefix="pfx", s3_client=cast(S3Client, s3)
    )
    t1 = datetime(2026, 1, 1, 10, 0, 0, tzinfo=timezone.utc)
    t2 = datetime(2026, 1, 1, 11, 0, 0, tzinfo=timezone.utc)
    t3 = datetime(2026, 1, 1, 12, 0, 0, tzinfo=timezone.utc)
    # Feed entries out of order: t2, t1, t3
    entries = [
        AuditEntry(id="req-1", timestamp=t2, message="second"),
        AuditEntry(id="req-1", timestamp=t1, message="first"),
        AuditEntry(id="req-1", timestamp=t3, message="third"),
    ]

    writer.write("req-1", entries)

    body: bytes = cast(
        bytes,
        cast(dict[str, object], cast(MagicMock, s3.put_object).call_args[1])["Body"],
    )
    lines = gzip.decompress(body).decode("utf-8").splitlines()
    messages = [cast(dict[str, object], json.loads(line))["message"] for line in lines]
    assert messages == ["first", "second", "third"]


