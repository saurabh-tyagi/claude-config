def test_get_dynamodb_request_repository_requires_table_env_var(
    monkeypatch: MonkeyPatch,
):
    monkeypatch.delenv(DYNAMO_DB_TABLE_ENV_VAR, raising=False)
    monkeypatch.setenv(DYNAMO_DB_INDEX_ENV_VAR, "state-index")

    with pytest.raises(ValueError, match=f"{DYNAMO_DB_TABLE_ENV_VAR} was not set"):
        _ = get_dyanmodb_request_repository()


def test_get_dynamodb_request_repository_requires_index_env_var(
