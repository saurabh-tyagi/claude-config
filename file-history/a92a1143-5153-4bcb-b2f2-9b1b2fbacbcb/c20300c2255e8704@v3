def test_dynamodb_repository_get_returns_none_when_item_missing():
    client = StubDynamoDBClient(get_item_response={})
    repository = DynamoDBRequestRepository(
        table_name="requests",
        index_name="state-index",
        dynamodb=cast(DynamoDBClient, cast(object, client)),
    )

    result = repository.get("req-123")

    assert result is None
    assert client.get_item_calls == [
        {"TableName": "requests", "Key": {"id": {"S": "req-123"}}}
    ]


def test_dynamodb_repository_get_all_in_state_queries_index_and_returns_requests():
    client = StubDynamoDBClient()
    paginator = StubPaginator(
        pages=[
            {},
            {
                "Items": [
                    DynamoDBRequestRepository.item_from_request(
                        make_request(id="req-1", state="new")
                    ),
                    DynamoDBRequestRepository.item_from_request(
                        make_request(
                            id="req-2",
                            state="new",
                            date_issued=datetime(
                                2023, 1, 1, 13, 0, 0, tzinfo=timezone.utc
                            ),
                        )
                    ),
                ]
            },
        ]
    )
    client.paginators["query"] = paginator
    repository = DynamoDBRequestRepository(
        table_name="requests",
        index_name="state-index",
        dynamodb=cast(DynamoDBClient, cast(object, client)),
    )

    results = repository.get_all_in_state("new", limit=2)

    assert [request.id for request in results] == ["req-1", "req-2"]
    assert paginator.paginate_calls == [
        {
            "TableName": "requests",
            "IndexName": "state-index",
            "Select": "ALL_ATTRIBUTES",
            "ScanIndexForward": True,
            "KeyConditionExpression": "#S = :state",
            "ExpressionAttributeNames": {"#S": "state"},
            "ExpressionAttributeValues": {":state": {"S": "new"}},
            "PaginationConfig": {"PageSize": 2, "MaxItems": 2},
        }
    ]


def test_dynamodb_repository_get_all_in_state_adds_from_date_to_query():
    client = StubDynamoDBClient()
