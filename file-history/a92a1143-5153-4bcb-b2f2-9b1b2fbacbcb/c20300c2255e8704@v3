def test_get_dynamodb_request_repository_builds_repository_from_environment(
    monkeypatch: MonkeyPatch,
):
    stub_client = object()
    monkeypatch.setenv(DYNAMO_DB_TABLE_ENV_VAR, "requests")
    monkeypatch.setenv(DYNAMO_DB_INDEX_ENV_VAR, "state-index")

    def stub_boto3_client(service_name: str) -> object:
        assert service_name == "dynamodb"
        return stub_client

    monkeypatch.setattr(
        "dns_de_rte_orchestrator.request_repository.boto3.client",
        stub_boto3_client,
    )

    repository = get_dyanmodb_request_repository()

    assert isinstance(repository, DynamoDBRequestRepository)
    assert repository.table_name == "requests"
    assert repository.index_name == "state-index"
    assert repository.dynamodb is stub_client


