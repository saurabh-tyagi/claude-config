def test_get_all_in_state(dynamodb_table: Table):
    assert dynamodb_table.item_count == 0, "Should be empty"

    test_id = "foo"
    time = datetime(year=2020, month=1, day=25, hour=12, minute=35, second=22)
    erasure_details: dict[ErasureDetailKey, str] = {"email": "foo@bar.com"}
    source = "tests"
    state = "new"
    _ = dynamodb_table.put_item(
        Item={
            DynamoDBRequestRepository.ID_FIELD: test_id,
            DynamoDBRequestRepository.SOURCE_FIELD: source,
            DynamoDBRequestRepository.STATE_FIELD: state,
            DynamoDBRequestRepository.DATE_ISSUED_FIELD: int(time.timestamp() * 1000),
            DynamoDBRequestRepository.ERASURE_DETAILS_FIELD: cast(
                dict[str, str], erasure_details
            ),
        }
    )

    repo = build_repository()

    result = repo.get_all_in_state(state=state)
    assert len(result) != 0, "Should have found items"

    site_ids: list[int] = []
    expected = [
        ErasureRequest(
            id=test_id,
            source=source,
            state=state,
            date_issued=time,
            erasure_details=erasure_details,
            site_ids=site_ids,
        )
    ]
    assert result == expected, "Should have found item"

    time_from = datetime(year=1990, month=1, day=1, hour=12, minute=10, second=5)
    result = repo.get_all_in_state(state=state, limit=2000, from_date=time_from)
    assert result == expected, "Should have found item within time frame"

    time_from = time + timedelta(days=2)
    result = repo.get_all_in_state(state=state, limit=20, from_date=time_from)
    assert len(result) == 0, "Should not have found item within time frame"


def test_get_all_in_state_paged(dynamodb_table: Table):
    assert dynamodb_table.item_count == 0, "Should be empty"

    id_prefix = "test_paged_"
    count_to_generate = 579
    date_issued = datetime(year=2020, month=1, day=25, hour=12, minute=35, second=22)
    erasure_details = {"email": "foo@bar.com"}
    source = "tests"
    state = "new"

    # Put a whole load of items into the table
    for i in range(count_to_generate):
        test_id = f"{id_prefix}{i}"
        unique_date_issued = date_issued + timedelta(seconds=i)
        _ = dynamodb_table.put_item(
            Item={
                DynamoDBRequestRepository.ID_FIELD: test_id,
                DynamoDBRequestRepository.SOURCE_FIELD: source,
                DynamoDBRequestRepository.STATE_FIELD: state,
                DynamoDBRequestRepository.DATE_ISSUED_FIELD: int(
                    unique_date_issued.timestamp() * 1000
                ),
                DynamoDBRequestRepository.ERASURE_DETAILS_FIELD: erasure_details,
            }
        )

    repo = build_repository()

    search_limit = count_to_generate + 10
    result = repo.get_all_in_state(state=state, limit=search_limit)
    assert len(result) == count_to_generate, "Should have found all items"

    seen_ids: set[str] = set()
    for erasure in result:
        assert erasure.state == state, "Wrong state"
        assert erasure.source == source, "Wrong source"
        assert erasure.erasure_details == erasure_details, "Wrong erasure_details"
        assert erasure.id.startswith(id_prefix), "Wrong id"
        assert (
            erasure.id not in seen_ids
        ), "Should not have returned the same item multiple times"
        seen_ids.add(erasure.id)

        # Check the date is as expected, we added seconds and can infer the
        # count from the id
        added_seconds = int(erasure.id[len(id_prefix) :])
        expected_date = date_issued + timedelta(seconds=added_seconds)
        assert erasure.date_issued == expected_date, "Wrong date"

    search_limit = 500
    expected_max_date = date_issued + timedelta(seconds=search_limit)
    result = repo.get_all_in_state(state=state, limit=search_limit)
    assert len(result) == search_limit, f"Should have found only {search_limit} items"
    for erasure in result:
        assert erasure.state == state, "Wrong state"
        assert erasure.source == source, "Wrong source"
        assert erasure.erasure_details == erasure_details, "Wrong erasure_details"
        assert erasure.id.startswith(id_prefix), "Wrong id"
        assert erasure.date_issued >= date_issued
        # Should be the first 500 entries if we've done everything in order
        assert erasure.date_issued < expected_max_date

    search_limit = count_to_generate + 10
    search_date = date_issued + timedelta(days=20)
    result = repo.get_all_in_state(
        state=state, limit=search_limit, from_date=search_date
    )
    assert len(result) == 0, "Should not have found any items"

    search_date = expected_max_date
    result = repo.get_all_in_state(
        state=state, limit=search_limit, from_date=search_date
    )
    assert len(result) == 79, "Should have found limited number of items"
