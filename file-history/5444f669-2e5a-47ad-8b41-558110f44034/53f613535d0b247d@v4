def test_process_phase3_moves_request_back_to_need_more_detail_when_customer_still_exists():
    request: ErasureRequest = ErasureRequest(
        id="test_id",
        source="test_system",
        state="phase-3",
        date_issued=datetime.now(),
        erasure_details={"email": "test@example.com"},
        site_ids=[],
        erasure_service_id="svc-123",
    )
    repo = InMemoryRequestRepository()
    repo.create(request)
    audit = InMemoryAuditLogger()
    customer_api = RecordingCustomerAPI()
    customer_api.add_results_for(
        "test@example.com",
        None,
        [
            CustomerDetails(
                first_name="Test",
                last_name="Customer",
                email="test@example.com",
                site_id=None,
                mobile_number=None,
                loyalty_number=None,
                och_id=None,
                digital_identity_id=None,
            )
        ],
    )
    proc = make_processor(
        repository=repo,
        audit=audit,
        as400=NoOpAS400Notifier(),
        customer_api=customer_api,
        erasures_api=StubErasuresAPI(),
    )

    with pytest.raises(StillExistsAfterErasure) as exc_info:
