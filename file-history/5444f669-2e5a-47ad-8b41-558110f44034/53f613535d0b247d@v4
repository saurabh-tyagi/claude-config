class RecordingZendeskAPI(ZendeskErasureAPI):

    def __init__(
        self,
        tickets: list[ZendeskTicketId] | None = None,
        users: list[ZendeskUserId] | None = None,
    ) -> None:
        super().__init__()
        self.tickets: list[ZendeskTicketId] = tickets or []
        self.users: list[ZendeskUserId] = users or []
        self.calls: list[tuple[str, object]] = []

    @override
    def find_tickets(self, request: ErasureRequest) -> list[str]:
        self.calls.append(("find_tickets", request.id))
        return self.tickets

    @override
    def delete_tickets(self, tickets: list[str]) -> None:
        self.calls.append(("delete_tickets", list(tickets)))

    @override
    def purge_tickets(self, tickets: list[str]) -> None:
        self.calls.append(("purge_tickets", list(tickets)))

    @override
    def find_users(self, request: ErasureRequest) -> list[str]:
        self.calls.append(("find_users", request.id))
        return self.users

    @override
    def delete_user(self, user: str) -> None:
        self.calls.append(("delete_user", user))

    @override
    def purge_user(self, user: str) -> None:
        self.calls.append(("purge_user", user))


class FailingZendeskAPI(RecordingZendeskAPI):

    @override
    def find_users(self, request: ErasureRequest) -> list[str]:
        self.calls.append(("find_users", request.id))
        raise RuntimeError("zendesk failed")


class RecordingRequestRepository(InMemoryRequestRepository):

    def __init__(self) -> None:
        super().__init__()
        self.update_calls: int = 0

    @override
    def create(self, request: ErasureRequest) -> None:
        super().create(deepcopy(request))

    @override
    def update(self, request: ErasureRequest) -> None:
        self.update_calls += 1
        super().update(deepcopy(request))


def make_processor(
    repository: InMemoryRequestRepository,
    audit: InMemoryAuditLogger | NoOpAuditLogger,
    as400: NoOpAS400Notifier,
    customer_api: CustomerAPIClient,
    erasures_api: CustomerErasureAPI,
    zendesk: ZendeskErasureAPI | None = None,
) -> RequestProcessor:
    return RequestProcessor(
        repository=repository,
        audit=audit,
        as400=as400,
        customer_api=customer_api,
        erasures_api=erasures_api,
        zendesk=zendesk or NoOpZendeskErasureAPI(),
    )


