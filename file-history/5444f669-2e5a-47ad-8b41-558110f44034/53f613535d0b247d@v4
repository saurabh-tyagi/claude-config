class StubCustomerAPI(CustomerAPIClient):

    def __init__(self) -> None:
        super().__init__()
        self._stored_details: dict[
            tuple[str, CustomerAPISiteID | None], list[CustomerDetails]
        ] = {}

    @override
    def get_customer_details(
        self, email: str, site_id: CustomerAPISiteID | None = None
    ) -> list[CustomerDetails]:
        key = (email, site_id)
        if key in self._stored_details:
            return self._stored_details[key]
        return []

    def add_results_for(
        self,
        email: str,
        site_id: CustomerAPISiteID | None,
        results: list[CustomerDetails],
    ) -> None:
        if len(results) <= 0:
            return
        key = (email, site_id)
        existing_list = self._stored_details.get(key)
        if not existing_list:
            existing_list = []
        existing_list.extend(results)
        self._stored_details[key] = existing_list


class RecordingCustomerAPI(StubCustomerAPI):

    def __init__(self) -> None:
        super().__init__()
        self.calls: list[tuple[str, CustomerAPISiteID | None]] = []

    @override
    def get_customer_details(
        self, email: str, site_id: CustomerAPISiteID | None = None
    ) -> list[CustomerDetails]:
        self.calls.append((email, site_id))
        return super().get_customer_details(email, site_id)


class StubErasuresAPI(CustomerErasureAPI):

    def __init__(self) -> None:
        super().__init__()
        self.responses: dict[str, ErasureAPIResponse] = {}

    @override
    def check_erasure(self, request: ErasureRequest) -> ErasureAPIResponse:
        key = request.erasure_service_id
        if key is None:
            raise ValueError("Missing erasure service id")
        result = self.responses.get(key)
        if result is None:
            raise ValueError(f"id {key} not in API")
        return result

    @override
    def trigger_erasure(self, request: ErasureRequest) -> CustomerErasureAPIRequestId:
        if request.erasure_service_id is not None:
            raise ValueError("Already raised with erasure service")

        result = self.generate_default_entry(request)
        request.erasure_service_id = result.request_id
        return request.erasure_service_id

    def generate_default_entry(self, _request: ErasureRequest) -> ErasureAPIResponse:
        uid = str(uuid.uuid4())
        tasks: dict[str, ErasureAPITask] = {}
        # TODO: Not sure what a default set of tasks should look like
        return ErasureAPIResponse(uid, tasks)


class DeterministicTriggerErasuresAPI(StubErasuresAPI):

    @override
    def generate_default_entry(self, _request: ErasureRequest) -> ErasureAPIResponse:
        tasks: dict[str, ErasureAPITask] = {}
        return ErasureAPIResponse("svc-123", tasks)


class RecordingCheckErasuresAPI(StubErasuresAPI):

    def __init__(self) -> None:
        super().__init__()
        self.check_calls: list[str | None] = []

    @override
    def check_erasure(self, request: ErasureRequest) -> ErasureAPIResponse:
        self.check_calls.append(request.erasure_service_id)
        key = request.erasure_service_id
        if key is None:
            raise ValueError("Missing erasure service id")
        result = self.responses.get(key)
        if result is not None:
            return result
        return ErasureAPIResponse(
            "svc-123",
            {"send-email": ErasureAPITask("SUCCESS", None)},
        )


