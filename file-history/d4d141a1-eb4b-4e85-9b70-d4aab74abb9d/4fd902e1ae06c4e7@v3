import json
from unittest.mock import patch

import pytest
from botocore.exceptions import ClientError

import app


def _client_error(code="AccessDeniedException"):
    return ClientError({"Error": {"Code": code, "Message": "Denied"}}, "Search")


class TestLambdaHandler:
    def test_error_response_hides_internal_details(self):
        with patch("app.run", side_effect=_client_error()):
            response = app.lambda_handler({}, None)

        assert response["statusCode"] == 500
        body = json.loads(response["body"])
        assert body["error"] == "Internal server error"
        assert "AccessDeniedException" not in response["body"]
        assert "Denied" not in response["body"]

    def test_error_response_hides_arbitrary_exception_details(self):
        secret_msg = "arn:aws:iam::334512769709:role/internal-role"
        with patch("app.run", side_effect=RuntimeError(secret_msg)):
            response = app.lambda_handler({}, None)

        assert response["statusCode"] == 500
        assert secret_msg not in response["body"]
        assert json.loads(response["body"])["error"] == "Internal server error"

    def test_successful_response_returns_200(self):
        from models import ScanResult

        with patch("app.run", return_value=ScanResult(resources=[], exclusion_counts={}, diff=None)):
            response = app.lambda_handler({}, None)

        assert response["statusCode"] == 200
        assert response["headers"]["Content-Type"] == "application/json"

    def test_query_string_overrides_are_ignored(self):
        """Event body / query-string params must not override env-var config."""
        from models import ScanResult

        captured = {}

        def fake_run(required_tags, **kwargs):
            captured["required_tags"] = required_tags
            return ScanResult(resources=[], exclusion_counts={}, diff=None)

        env = {"RequiredTags": "team,product"}
        event_with_override = {
            "queryStringParameters": {"required_tags": "hacker_tag"},
            "body": '{"required_tags": ["hacker_tag"]}',
        }
        with patch("app.run", side_effect=fake_run), patch.dict("os.environ", env, clear=False):
            app.lambda_handler(event_with_override, None)

        assert captured["required_tags"] == ["team", "product"]
