_SERVICE_DEFAULT_TYPE = {
    "ec2": "ec2:instance",
    "lambda": "lambda:function",
    "s3": "s3:bucket",
    "rds": "rds:db",
    "glue": "glue:job",
    "sqs": "sqs:queue",
    "sns": "sns:topic",
    "kinesis": "kinesis:stream",
    "dynamodb": "dynamodb:table",
}


def _make_item(resource_id: str, service: str, tags: dict, resource_type: str = None) -> dict:
    """Build a Resource Explorer resource entry."""
    rt = resource_type or _SERVICE_DEFAULT_TYPE.get(service, f"{service}:instance")
    item = {
        "Arn": f"arn:aws:{service}:{REGION}:{ACCOUNT}:resource/{resource_id}",
        "Region": REGION,
        "ResourceType": rt,
        "Properties": [
            {
                "Name": "tags",
                "Data": [{"Key": k, "Value": v} for k, v in tags.items()],
            }
        ],
    }
    return item


def _make_session(pages: list) -> MagicMock:
    """Build a mock boto3 Session whose resource-explorer-2 list_resources paginator
    yields the given list of pages (each page is a list of resource items)."""
    session = MagicMock()
    client = MagicMock()
    paginator = MagicMock()

    paginator.paginate.return_value = [
        {"Resources": page} for page in pages
    ]
    client.get_paginator.return_value = paginator
    session.client.return_value = client
    return session


def _make_multi_query_session(tag_to_pages: dict) -> MagicMock:
    """Build a mock Session for multi-tag queries.

    tag_to_pages maps a tag key string (e.g. "team") to a list of pages.
    The paginator returns the matching pages based on the -tag.key: term in FilterString.
    """
    session = MagicMock()
    client = MagicMock()

    def make_paginator(_op):
        paginator = MagicMock()
        def paginate(Filters):
            fs = Filters["FilterString"]
            for tag, pages in tag_to_pages.items():
                if f"-tag.key:{tag}" in fs:
                    return [{"Resources": page} for page in pages]
            # No-tag query (None key)
            if None in tag_to_pages:
                return [{"Resources": page} for page in tag_to_pages[None]]
            return [{"Resources": []}]
        paginator.paginate.side_effect = paginate
        return paginator

    client.get_paginator.side_effect = make_paginator
    session.client.return_value = client
    return session


