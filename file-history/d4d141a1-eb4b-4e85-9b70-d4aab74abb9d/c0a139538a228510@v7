class TestBuildFilterString:
    def test_required_tag_becomes_negative_tag_key_term(self):
        result = _build_filter_string("team")
        assert "-tag.key:team" in result

    def test_always_includes_resourcetype_supports_tags(self):
        result = _build_filter_string(None)
        assert "resourcetype.supports:tags" in result

    def test_always_scoped_to_eu_west_1(self):
        result = _build_filter_string(None)
        assert f"region:{_REGION}" in result

    def test_no_required_tag_omits_tag_key_term(self):
        result = _build_filter_string(None)
        assert "-tag.key:" not in result

    def test_full_example_with_tag(self):
        result = _build_filter_string("team")
        assert result == "-tag.key:team resourcetype.supports:tags region:eu-west-1"

    def test_full_example_without_tag(self):
        result = _build_filter_string(None)
        assert result == "resourcetype.supports:tags region:eu-west-1"

    def test_filter_string_stays_under_api_limit(self):
        """Resource Explorer's FilterString is capped at 2048 characters."""
        result = _build_filter_string("team")
        assert len(result) <= 2048, f"FilterString length {len(result)} exceeds 2048-char limit"


