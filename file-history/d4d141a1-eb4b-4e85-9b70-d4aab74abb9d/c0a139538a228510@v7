class TestScanUntaggedResources:

    def test_resource_is_returned(self):
        item = _make_item("res-1", "lambda", {"team": "de"})
        session = _make_session([[item]])
        results = scan_untagged_resources(session, required_tags=["team", "product"])
        assert len(results) == 1
        assert results[0].name == "res-1"

    def test_arn_and_region_are_mapped(self):
        item = _make_item("res-1", "ec2", {})
        session = _make_session([[item]])
        results = scan_untagged_resources(session)
        assert results[0].arn == item["Arn"]
        assert results[0].region == REGION

    def test_existing_tags_are_preserved(self):
        item = _make_item("res-1", "lambda", {"team": "de"})
        session = _make_session([[item]])
        results = scan_untagged_resources(session, required_tags=["team", "product"])
        assert results[0].tags == {"team": "de"}

    def test_resource_type_from_api_field(self):
        item = _make_item("my-func", "lambda", {}, resource_type="lambda:function")
        session = _make_session([[item]])
        results = scan_untagged_resources(session)
        assert results[0].resource_type == "lambda:function"

    def test_resource_type_falls_back_to_arn_parsing(self):
        item = _make_item("my-func", "lambda", {})
        item["Arn"] = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func"
        del item["ResourceType"]
        session = _make_session([[item]])
        results = scan_untagged_resources(session)
        assert results[0].resource_type == "lambda:function"

    def test_multiple_pages_are_collected(self):
        page1 = [_make_item("res-1", "ec2", {})]
        page2 = [_make_item("res-2", "ec2", {})]
        session = _make_session([page1, page2])
        results = scan_untagged_resources(session)
        assert len(results) == 2

    def test_filter_string_passed_to_paginator(self):
        session = _make_session([[]])
        scan_untagged_resources(session, required_tags=["team"])
        paginator = session.client.return_value.get_paginator.return_value
        filter_string = paginator.paginate.call_args[1]["Filters"]["FilterString"]
        assert "-tag.key:team" in filter_string
        assert "resourcetype.supports:tags" in filter_string
        assert "region:eu-west-1" in filter_string

    def test_multiple_tags_union_results(self):
        item_a = _make_item("res-a", "ec2", {})
        item_b = _make_item("res-b", "lambda", {})
        session = _make_multi_query_session({
            "team": [[item_a]],
            "product": [[item_b]],
        })
        results = scan_untagged_resources(session, required_tags=["team", "product"])
        arns = {r.arn for r in results}
        assert item_a["Arn"] in arns
        assert item_b["Arn"] in arns

    def test_multiple_tags_deduplicates_by_arn(self):
        item = _make_item("res-1", "ec2", {})
        session = _make_multi_query_session({
            "team": [[item]],
            "product": [[item]],
        })
        results = scan_untagged_resources(session, required_tags=["team", "product"])
        assert len(results) == 1

    def test_no_tags_runs_single_query_without_tag_filter(self):
        item = _make_item("res-1", "ec2", {})
        session = _make_multi_query_session({None: [[item]]})
        results = scan_untagged_resources(session, required_tags=[])
        assert len(results) == 1
        assert results[0].arn == item["Arn"]

    def test_one_query_issued_per_required_tag(self):
        session = _make_multi_query_session({"team": [[]], "product": [[]]})
        scan_untagged_resources(session, required_tags=["team", "product"])
        client = session.client.return_value
        assert client.get_paginator.call_count == 2

    def test_results_sorted_by_resource_type_then_name(self):
        s3 = _make_item("zebra-bucket", "s3", {}, resource_type="s3:bucket")
        lambda_b = _make_item("b-func", "lambda", {}, resource_type="lambda:function")
        lambda_a = _make_item("a-func", "lambda", {}, resource_type="lambda:function")
        ec2 = _make_item("i-xyz", "ec2", {}, resource_type="ec2:instance")
        session = _make_session([[s3, lambda_b, ec2, lambda_a]])

        results = scan_untagged_resources(session)

        types_and_names = [(r.resource_type, r.name) for r in results]
        assert types_and_names == [
            ("ec2:instance", "i-xyz"),
            ("lambda:function", "a-func"),
            ("lambda:function", "b-func"),
            ("s3:bucket", "zebra-bucket"),
        ]

    def test_excluded_resource_type_is_dropped(self):
        vpc = _make_item("vpc-1", "ec2", {}, resource_type="ec2:vpc")
        instance = _make_item("i-1", "ec2", {}, resource_type="ec2:instance")
        session = _make_session([[vpc, instance]])
        results = scan_untagged_resources(session)
        types = {r.resource_type for r in results}
        assert "ec2:vpc" not in types
        assert "ec2:instance" in types

    def test_unknown_new_service_type_passes_through(self):
        # A brand-new AWS service type not in the exclusion list should appear in results.
        item = _make_item("res-1", "newservice", {}, resource_type="newservice:widget")
        session = _make_session([[item]])
        results = scan_untagged_resources(session)
        assert any(r.resource_type == "newservice:widget" for r in results)

    def test_custom_excluded_types_override_default(self):
        ec2_item = _make_item("i-1", "ec2", {}, resource_type="ec2:instance")
        session = _make_session([[ec2_item]])
        results = scan_untagged_resources(session, excluded_resource_types={"ec2:instance"})
        assert results == []

    def test_uses_resource_explorer_client_in_eu_west_1(self):
        session = _make_session([[]])
        scan_untagged_resources(session)
        session.client.assert_called_once_with("resource-explorer-2", region_name="eu-west-1")

    def test_non_iterable_tags_data_is_handled_gracefully(self):
        item = _make_item("res-1", "ec2", {})
        item["Properties"] = [{"Name": "tags", "Data": "unexpected-string"}]
        session = _make_session([[item]])
        results = scan_untagged_resources(session)
        assert results[0].tags == {}

    def test_missing_properties_field_is_handled_gracefully(self):
        item = {
            "Arn": f"arn:aws:ec2:{REGION}:{ACCOUNT}:instance/i-abc123",
            "Region": REGION,
            "ResourceType": "ec2:instance",
        }
        session = _make_session([[item]])
        results = scan_untagged_resources(session)
        assert results[0].tags == {}

    def test_client_error_is_re_raised(self):
        session = MagicMock()
        client = MagicMock()
        client.get_paginator.side_effect = ClientError(
            {"Error": {"Code": "AccessDeniedException", "Message": "Denied"}},
            "ListResources",
        )
        session.client.return_value = client
        with pytest.raises(ClientError):
            scan_untagged_resources(session)

    def test_generic_exception_is_re_raised(self):
        session = MagicMock()
        client = MagicMock()
        client.get_paginator.side_effect = RuntimeError("unexpected")
        session.client.return_value = client
        with pytest.raises(RuntimeError):
            scan_untagged_resources(session)
