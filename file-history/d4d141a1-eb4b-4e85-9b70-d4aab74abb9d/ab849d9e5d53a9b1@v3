version=0.1
[dev.deploy.parameters]
region = "eu-west-1"
role_arn="arn:aws:iam::334512769709:role/gitlab-ci-de-untagged-reporter-deployer"
s3_bucket = "hbi-shared-samfunctions-datalake"
s3_prefix = "data-de/untagged-reporter/dev"
tags = """
    application="data-de-untagged-reporter"
    managed_by="aws-sam"
    owner="data"
    team="de"
    vertical="data"
    repository="https://gitlab.com/hnbi/dns/dns-de-automation"
    product="untagged reporter"
    project="untagged reporter"
    name="untagged reporter"
"""
capabilities = "CAPABILITY_NAMED_IAM CAPABILITY_AUTO_EXPAND"
stack_name = "data-de-untagged-reporter-dev"
parameter_overrides = """
    Environment=dev
    Region=eu-west-1
    RequiredTags=team,product
    CheckpointS3Path=s3://hbi-dns-assets/untagged_reporter/dev
    ExcludeCategories=
"""

