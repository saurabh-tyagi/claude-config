import csv
import io
import json
from io import BytesIO
from unittest.mock import MagicMock, patch

import pytest
from botocore.exceptions import ClientError
from botocore.stub import Stubber

from checkpoint import diff_reports, load_checkpoint, parse_s3_path, save_checkpoint
from models import CheckpointDiff, UntaggedResource

BUCKET = "test-bucket"
KEY = "path/to/checkpoint.csv"
REGION = "eu-west-1"
ACCOUNT = "123456789012"


def _resource(name: str, service: str = "lambda") -> UntaggedResource:
    return UntaggedResource(
        arn=f"arn:aws:{service}:{REGION}:{ACCOUNT}:function/{name}",
        resource_type=f"{service}:function",
        region=REGION,
        name=name,
    )


def _csv_bytes(resources):
    lines = ["arn,name,resource_type,region"]
    for r in resources:
        lines.append(f"{r.arn},{r.name},{r.resource_type},{r.region}")
    return "\n".join(lines).encode("utf-8")


def _make_session(s3_mock):
    session = MagicMock()
    session.client.return_value = s3_mock
    return session


