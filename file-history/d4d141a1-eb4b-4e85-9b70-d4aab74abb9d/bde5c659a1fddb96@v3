class TestParseS3Path:
    def test_basic_path_with_prefix(self):
        bucket, key = parse_s3_path("s3://my-bucket/dns/untagged-reporter/dev")
        assert bucket == "my-bucket"
        assert key == "dns/untagged-reporter/dev/checkpoint.csv"

    def test_trailing_slash_is_stripped(self):
        bucket, key = parse_s3_path("s3://my-bucket/dns/untagged-reporter/dev/")
        assert bucket == "my-bucket"
        assert key == "dns/untagged-reporter/dev/checkpoint.csv"

    def test_bucket_only_no_prefix(self):
        bucket, key = parse_s3_path("s3://my-bucket")
        assert bucket == "my-bucket"
        assert key == "checkpoint.csv"

    def test_bucket_with_trailing_slash_only(self):
        bucket, key = parse_s3_path("s3://my-bucket/")
        assert bucket == "my-bucket"
        assert key == "checkpoint.csv"

    def test_invalid_scheme_raises_value_error(self):
        with pytest.raises(ValueError, match="Invalid S3 path"):
            parse_s3_path("https://my-bucket/path")

    def test_no_scheme_raises_value_error(self):
        with pytest.raises(ValueError, match="Invalid S3 path"):
            parse_s3_path("my-bucket/path")
