class TestDiffReports:
    def test_all_new_when_previous_empty(self):
        current = [_resource("func-a"), _resource("func-b")]
        diff = diff_reports([], current)
        assert len(diff.added) == 2
        assert diff.removed == []

    def test_all_removed_when_current_empty(self):
        previous = [_resource("func-a"), _resource("func-b")]
        diff = diff_reports(previous, [])
        assert diff.added == []
        assert len(diff.removed) == 2

    def test_no_changes_when_identical(self):
        resources = [_resource("func-a"), _resource("func-b")]
        diff = diff_reports(resources, resources)
        assert diff.added == []
        assert diff.removed == []

    def test_detects_single_addition(self):
        previous = [_resource("func-a")]
        current = [_resource("func-a"), _resource("func-b")]
        diff = diff_reports(previous, current)
        assert len(diff.added) == 1
        assert diff.added[0].name == "func-b"
        assert diff.removed == []

    def test_detects_single_removal(self):
        previous = [_resource("func-a"), _resource("func-b")]
        current = [_resource("func-a")]
        diff = diff_reports(previous, current)
        assert diff.added == []
        assert len(diff.removed) == 1
        assert diff.removed[0].name == "func-b"

    def test_detects_simultaneous_add_and_remove(self):
        previous = [_resource("old-func")]
        current = [_resource("new-func")]
        diff = diff_reports(previous, current)
        assert len(diff.added) == 1
        assert diff.added[0].name == "new-func"
        assert len(diff.removed) == 1
        assert diff.removed[0].name == "old-func"

    def test_diff_uses_arn_for_comparison(self):
        # Same ARN — should not appear as added/removed even if name differs in object
        r_prev = UntaggedResource(
            arn=f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func",
            resource_type="lambda:function", region=REGION, name="my-func",
        )
        r_curr = UntaggedResource(
            arn=f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func",
            resource_type="lambda:function", region=REGION, name="my-func-renamed",
        )
        diff = diff_reports([r_prev], [r_curr])
        assert diff.added == []
        assert diff.removed == []

    def test_returns_checkpoint_diff_type(self):
        diff = diff_reports([], [])
        assert isinstance(diff, CheckpointDiff)

    def test_detects_tag_drift_on_same_arn(self):
        arn = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func"
        prev = UntaggedResource(arn=arn, resource_type="lambda:function", region=REGION, name="my-func", tags={"team": "de"})
        curr = UntaggedResource(arn=arn, resource_type="lambda:function", region=REGION, name="my-func", tags={})
        diff = diff_reports([prev], [curr])
        assert len(diff.retagged) == 1
        assert diff.retagged[0].arn == arn
        assert diff.added == []
        assert diff.removed == []

    def test_identical_tags_produce_no_retagged(self):
        arn = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func"
        r = UntaggedResource(arn=arn, resource_type="lambda:function", region=REGION, name="my-func", tags={"team": "de"})
        diff = diff_reports([r], [r])
        assert diff.retagged == []


