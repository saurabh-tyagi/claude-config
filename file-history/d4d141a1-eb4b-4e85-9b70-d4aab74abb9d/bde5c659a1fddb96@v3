class TestLoadCheckpoint:
    def test_returns_resources_from_csv(self):
        r = _resource("my-func")
        s3 = MagicMock()
        s3.get_object.return_value = {"Body": BytesIO(_csv_bytes([r]))}
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert len(result) == 1
        assert result[0].arn == r.arn
        assert result[0].name == r.name
        assert result[0].resource_type == r.resource_type
        assert result[0].region == r.region

    def test_returns_none_when_key_not_found(self):
        s3 = MagicMock()
        error = ClientError({"Error": {"Code": "NoSuchKey", "Message": ""}}, "GetObject")
        s3.get_object.side_effect = error
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert result is None

    def test_returns_none_for_404_code(self):
        s3 = MagicMock()
        error = ClientError({"Error": {"Code": "404", "Message": ""}}, "GetObject")
        s3.get_object.side_effect = error
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert result is None

    def test_raises_other_client_errors(self):
        s3 = MagicMock()
        error = ClientError({"Error": {"Code": "AccessDenied", "Message": ""}}, "GetObject")
        s3.get_object.side_effect = error
        with pytest.raises(ClientError):
            load_checkpoint(_make_session(s3), BUCKET, KEY)

    def test_returns_empty_list_for_empty_csv(self):
        s3 = MagicMock()
        s3.get_object.return_value = {"Body": BytesIO(b"arn,name,resource_type,region\n")}
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert result == []

    def test_tags_round_trip_through_csv(self):
        tags = {"team": "de", "product": "platform"}
        r = UntaggedResource(
            arn=f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func",
            resource_type="lambda:function",
            region=REGION,
            name="my-func",
            tags=tags,
        )
        buf = io.StringIO()
        writer = csv.DictWriter(buf, fieldnames=["arn", "name", "resource_type", "region", "tags"])
        writer.writeheader()
        writer.writerow({
            "arn": r.arn,
            "name": r.name,
            "resource_type": r.resource_type,
            "region": r.region,
            "tags": json.dumps(r.tags),
        })
        s3 = MagicMock()
        s3.get_object.return_value = {"Body": BytesIO(buf.getvalue().encode("utf-8"))}
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert result[0].tags == tags

    def test_legacy_checkpoint_without_tags_column_loads_with_empty_dict(self):
        csv_body = "arn,name,resource_type,region\n" \
                   f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func,my-func,lambda:function,{REGION}\n"
        s3 = MagicMock()
        s3.get_object.return_value = {"Body": BytesIO(csv_body.encode("utf-8"))}
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert result[0].tags == {}

    def test_multiple_resources_parsed(self):
        resources = [_resource("func-a"), _resource("func-b"), _resource("func-c")]
        s3 = MagicMock()
        s3.get_object.return_value = {"Body": BytesIO(_csv_bytes(resources))}
        result = load_checkpoint(_make_session(s3), BUCKET, KEY)
        assert len(result) == 3
        assert {r.name for r in result} == {"func-a", "func-b", "func-c"}


