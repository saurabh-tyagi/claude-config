@patch("app.boto3.Session")
def test_run_checkpoint_diff_is_none_without_path(mock_session_cls):
    mock_session_cls.return_value = _make_session_with_resources([])

    result = run(["team"])

    assert result.diff is None


@patch("app.boto3.Session")
def test_run_checkpoint_diff_is_none_on_first_run(mock_session_cls):
    # No existing checkpoint (NoSuchKey) → diff is None, checkpoint is saved
    mock_session_cls.return_value = _make_session_with_resources([], checkpoint_csv=b"")

    result = run(["team"], checkpoint_s3_path="s3://my-bucket/path")

    assert result.diff is None  # first run — no previous data to diff


@patch("app.boto3.Session")
def test_run_checkpoint_diff_shows_added_and_removed(mock_session_cls):
    # Previous checkpoint has func-old; current scan returns func-new
    prev_csv = b"arn,name,resource_type,region\narn:aws:lambda:eu-west-1:123:function/func-old,func-old,lambda:function,eu-west-1\n"
    item = _make_explorer_item("func-new", "lambda", {})
    item["Arn"] = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/func-new"
    mock_session_cls.return_value = _make_session_with_resources([item], checkpoint_csv=prev_csv)

    result = run(["team"], checkpoint_s3_path="s3://my-bucket/path")

    assert result.diff is not None
    assert len(result.diff.added) == 1
    assert result.diff.added[0].name == "func-new"
    assert len(result.diff.removed) == 1
    assert result.diff.removed[0].name == "func-old"


@patch("app.boto3.Session")
def test_lambda_handler_diff_in_json_response(mock_session_cls, mock_env, monkeypatch):
    monkeypatch.setenv("CheckpointS3Path", "s3://my-bucket/path")
    prev_csv = b"arn,name,resource_type,region\narn:aws:lambda:eu-west-1:123:function/old-func,old-func,lambda:function,eu-west-1\n"
    item = _make_explorer_item("new-func", "lambda", {})
    item["Arn"] = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/new-func"
    mock_session_cls.return_value = _make_session_with_resources([item], checkpoint_csv=prev_csv)

    response = lambda_handler({}, {})

    body = json.loads(response["body"])
    assert body["total_untagged"] == 1
    changes = body["changes_since_last_checkpoint"]
    assert changes["continuing_untagged"] == 0
    assert changes["new_untagged"] == 1
    assert changes["no_longer_untagged"] == 1
    assert changes["tags_changed"] == 0
    assert "continuing_untagged_resources" not in changes
    assert changes["new_untagged_resources"][0] == {
        "name": "new-func",
        "type": "lambda:function",
        "arn": f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/new-func",
    }
    assert changes["no_longer_untagged_resources"][0]["name"] == "old-func"
    assert changes["tags_changed_resources"] == []
