import json
from io import BytesIO
from unittest.mock import MagicMock, patch

import pytest

from app import lambda_handler, run

ACCOUNT = "123456789012"
REGION = "eu-west-1"


def _make_explorer_item(resource_id: str, service: str, tags: dict) -> dict:
    """Build a Resource Explorer resource entry."""
    return {
        "Arn": f"arn:aws:{service}:{REGION}:{ACCOUNT}:resource/{resource_id}",
        "Region": REGION,
        "Properties": [
            {
                "Name": "tags",
                "Data": [{"Key": k, "Value": v} for k, v in tags.items()],
            }
        ],
    }


def _make_session_with_resources(items, checkpoint_csv: bytes = b""):
    """Build a mock boto3 Session for Resource Explorer and optionally S3."""
    session = MagicMock()
    explorer_client = MagicMock()
    paginator = MagicMock()
    paginator.paginate.return_value = [{"Resources": items}]
    explorer_client.get_paginator.return_value = paginator

    s3_client = MagicMock()
    if checkpoint_csv:
        s3_client.get_object.return_value = {"Body": BytesIO(checkpoint_csv)}
    else:
        from botocore.exceptions import ClientError
        s3_client.get_object.side_effect = ClientError(
            {"Error": {"Code": "NoSuchKey", "Message": ""}}, "GetObject"
        )

    def _client(service, **kwargs):
        if service == "resource-explorer-2":
            return explorer_client
        return s3_client

    session.client.side_effect = _client
    return session


@pytest.fixture
def mock_env(monkeypatch):
    monkeypatch.setenv("RequiredTags", "team,product")


# ---------------------------------------------------------------------------
# run() — core logic
# ---------------------------------------------------------------------------

@patch("app.boto3.Session")
def test_run_returns_untagged_resources(mock_session_cls):
    item = _make_explorer_item("my-func", "lambda", {"team": "de"})  # missing 'product'
    item["Arn"] = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func"
    mock_session_cls.return_value = _make_session_with_resources([item])

    result = run(["team", "product"])

    assert len(result.resources) == 1
    assert result.resources[0].name == "my-func"


@patch("app.boto3.Session")
def test_run_returns_empty_when_filter_returns_nothing(mock_session_cls):
    mock_session_cls.return_value = _make_session_with_resources([])

    result = run(["team", "product"])

    assert result.resources == []


@patch("app.boto3.Session")
def test_run_uses_profile_when_provided(mock_session_cls):
    mock_session_cls.return_value = _make_session_with_resources([])

    run(["team"], profile="my-profile")

    mock_session_cls.assert_called_once_with(profile_name="my-profile")


@patch("app.boto3.Session")
def test_run_exclude_categories_filters_matching_resources(mock_session_cls):
    item = _make_explorer_item("sagemaker-pipeline", "lambda", {})
    item["Arn"] = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/sagemaker-pipeline"
    mock_session_cls.return_value = _make_session_with_resources([item])

    result = run(["team"], exclude_categories=["data_science"])

    assert result.resources == []
    assert result.exclusion_counts["data_science"] == 1


