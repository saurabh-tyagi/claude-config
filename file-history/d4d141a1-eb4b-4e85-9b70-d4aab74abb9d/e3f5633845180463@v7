@patch("app.boto3.Session")
def test_lambda_handler_returns_json_response(mock_session_cls, mock_env):
    item = _make_explorer_item("my-func", "lambda", {"team": "de"})
    item["Arn"] = f"arn:aws:lambda:{REGION}:{ACCOUNT}:function/my-func"
    mock_session_cls.return_value = _make_session_with_resources([item])

    response = lambda_handler({}, {})

    assert response["statusCode"] == 200
    assert response["headers"]["Content-Type"] == "application/json"
    body = json.loads(response["body"])
    assert body["total_untagged"] == 1
    assert body["by_resource_type"] == {"lambda:function": 1}
    assert "changes_since_last_checkpoint" not in body  # no checkpoint configured



@patch("app.boto3.Session")
def test_lambda_handler_returns_500_on_error(mock_session_cls, mock_env):
    mock_session_cls.side_effect = RuntimeError("boom")

    response = lambda_handler({}, {})

    assert response["statusCode"] == 500
    assert "error" in json.loads(response["body"])


