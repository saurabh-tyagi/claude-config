import csv
import io
import json
import logging
from typing import Dict, List, Tuple

from tabulate import tabulate

from models import CheckpointDiff, ScanResult, UntaggedResource
from scanner import RESOURCE_TYPE_LABELS

logger = logging.getLogger(__name__)


def _label(resource_type: str) -> str:
    return RESOURCE_TYPE_LABELS.get(resource_type, resource_type)


def _split_by_status(
    result: ScanResult,
) -> Tuple[List[UntaggedResource], List[UntaggedResource], List[UntaggedResource]]:
    """Return (existing, added, removed) resource lists.

    existing = still untagged from previous run
    added    = newly untagged since last run  (diff.added)
    removed  = no longer untagged since last run (diff.removed)

    When no diff is available all resources are returned as existing.
    """
    if result.diff is None:
        return result.resources, [], []
    added_arns = {r.arn for r in result.diff.added}
    existing = [r for r in result.resources if r.arn not in added_arns]
    return existing, result.diff.added, result.diff.removed


def _counts_by_type(resources: List[UntaggedResource]) -> Dict[str, int]:
    counts: Dict[str, int] = {}
    for r in resources:
        counts[r.resource_type] = counts.get(r.resource_type, 0) + 1
    return dict(sorted(counts.items()))


def _table_section(title: str, resources: List[UntaggedResource]) -> str:
    headers = ["#", "Resource Name", "Type", "Region", "ARN"]
    rows = [
        [i, r.name, _label(r.resource_type), r.region, r.arn]
        for i, r in enumerate(resources, start=1)
    ]
    body = tabulate(rows, headers=headers, tablefmt="rounded_outline")
    return f"  {title}\n{body}"


def render_table(result: ScanResult) -> str:
    existing, added, removed = _split_by_status(result)

    if result.diff is None:
        return _table_section("Untagged Resources", existing)

    sections = []
    sections.append(_table_section(f"Continuing Untagged Resources ({len(existing)})", existing))
    sections.append(_table_section(f"New Untagged Resources ({len(added)})", added))
    sections.append(_table_section(f"Resources No Longer Untagged ({len(removed)})", removed))
    return "\n\n".join(sections)


def _resource_to_dict(r: UntaggedResource) -> dict:
    return {
        "name": r.name,
        "resource_type": r.resource_type,
        "resource_type_label": _label(r.resource_type),
        "region": r.region,
        "arn": r.arn,
    }


def _diff_to_dict(diff: CheckpointDiff, existing: List[UntaggedResource]) -> dict:
    return {
        "existing_count": len(existing),
        "added_count": len(diff.added),
        "removed_count": len(diff.removed),
        "existing_by_type": _counts_by_type(existing),
        "added_by_type": _counts_by_type(diff.added),
        "removed_by_type": _counts_by_type(diff.removed),
        "existing": [_resource_to_dict(r) for r in existing],
        "added": [_resource_to_dict(r) for r in diff.added],
        "removed": [_resource_to_dict(r) for r in diff.removed],
    }


def render_summary(result: ScanResult) -> str:
    resources = result.resources
    total = len(resources)

    lines = [
        "",
        "  Untagged Resource Report",
        f"  Total untagged resources : {total}",
        "",
        "  By resource type:",
    ]
    for rt, count in _counts_by_type(resources).items():
        lines.append(f"    {rt:<45} {count}")

    if result.exclusion_counts:
        lines.append("")
        lines.append("  Excluded by keyword category:")
        for cat, count in sorted(result.exclusion_counts.items()):
            lines.append(f"    {cat:<45} {count}")

    if result.diff is not None:
        existing, added, removed = _split_by_status(result)
        lines.append("")
        lines.append("  Changes since last checkpoint:")
        lines.append(f"    {'Continuing untagged':<45} {len(existing)}")
        lines.append(f"    {'New untagged':<45} {len(added)}")
        lines.append(f"    {'No longer untagged':<45} {len(removed)}")

    lines.append("")
    return "\n".join(lines)


def render_json(result: ScanResult) -> str:
    existing, added, removed = _split_by_status(result)

    if result.diff is None:
        data = {
            "total_resources": len(result.resources),
            "by_resource_type": _counts_by_type(result.resources),
            "excluded_by_category": result.exclusion_counts,
            "resources": [
                {"rank": i, **_resource_to_dict(r)}
                for i, r in enumerate(result.resources, start=1)
            ],
        }
    else:
        data = {
            "total_resources": len(result.resources),
            "by_resource_type": _counts_by_type(result.resources),
            "excluded_by_category": result.exclusion_counts,
            "diff": _diff_to_dict(result.diff, existing),
        }

    return json.dumps(data, indent=2)


def render_csv(result: ScanResult) -> str:
    existing, added, removed = _split_by_status(result)
    buf = io.StringIO()
    writer = csv.writer(buf)

    if result.diff is None:
        writer.writerow(["Rank", "Name", "Type", "Type Label", "Region", "ARN"])
        for i, r in enumerate(existing, start=1):
            writer.writerow([i, r.name, r.resource_type, _label(r.resource_type), r.region, r.arn])
    else:
        writer.writerow(["Status", "Name", "Type", "Type Label", "Region", "ARN"])
        for r in existing:
            writer.writerow(["existing", r.name, r.resource_type, _label(r.resource_type), r.region, r.arn])
        for r in added:
            writer.writerow(["new", r.name, r.resource_type, _label(r.resource_type), r.region, r.arn])
        for r in removed:
            writer.writerow(["removed", r.name, r.resource_type, _label(r.resource_type), r.region, r.arn])

    return buf.getvalue()
