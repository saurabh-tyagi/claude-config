import csv
import io
import json
import logging
from typing import List, Optional, Tuple

from botocore.exceptions import ClientError

from models import CheckpointDiff, UntaggedResource

logger = logging.getLogger(__name__)

_CSV_FIELDS = ["arn", "name", "resource_type", "region", "tags"]
_CHECKPOINT_FILENAME = "checkpoint.csv"


def parse_s3_path(s3_path: str) -> Tuple[str, str]:
    """Parse an S3 URI into (bucket, key), appending the hardcoded checkpoint filename.

    The caller provides only the directory path; the filename is always checkpoint.csv.

    Examples:
        "s3://my-bucket/dns/untagged-reporter/dev"   -> ("my-bucket", "dns/untagged-reporter/dev/checkpoint.csv")
        "s3://my-bucket/dns/untagged-reporter/dev/"  -> ("my-bucket", "dns/untagged-reporter/dev/checkpoint.csv")
        "s3://my-bucket"                             -> ("my-bucket", "checkpoint.csv")
    """
    if not s3_path.startswith("s3://"):
        raise ValueError(f"Invalid S3 path, expected s3://bucket/prefix: {s3_path!r}")
    without_scheme = s3_path[5:]
    bucket, _, prefix = without_scheme.partition("/")
    if not bucket:
        raise ValueError(f"Invalid S3 path, no bucket found: {s3_path!r}")
    prefix = prefix.rstrip("/")
    key = f"{prefix}/{_CHECKPOINT_FILENAME}" if prefix else _CHECKPOINT_FILENAME
    return bucket, key


def load_checkpoint(session, bucket: str, key: str) -> Optional[List[UntaggedResource]]:
    """Download the previous checkpoint from S3 and parse it.

    Returns None if the object does not exist (first run).
    Raises ClientError for any other S3 error.
    """
    client = session.client("s3")
    try:
        obj = client.get_object(Bucket=bucket, Key=key)
    except ClientError as e:
        if e.response["Error"]["Code"] in ("NoSuchKey", "404"):
            logger.info("No checkpoint found at s3://%s/%s — first run", bucket, key)
            return None
        raise
    body = obj["Body"].read().decode("utf-8")
    reader = csv.DictReader(io.StringIO(body))
    resources = [
        UntaggedResource(
            arn=row["arn"],
            name=row["name"],
            resource_type=row["resource_type"],
            region=row["region"],
            tags=json.loads(row.get("tags") or "{}"),
        )
        for row in reader
    ]
    logger.info("Loaded checkpoint from s3://%s/%s (%d resources)", bucket, key, len(resources))
    return resources


def save_checkpoint(session, bucket: str, key: str, resources: List[UntaggedResource]) -> None:
    """Upload the current resource list to S3 as a CSV checkpoint, overwriting any previous file."""
    buf = io.StringIO()
    writer = csv.DictWriter(buf, fieldnames=_CSV_FIELDS)
    writer.writeheader()
    for r in resources:
        writer.writerow({
            "arn": r.arn,
            "name": r.name,
            "resource_type": r.resource_type,
            "region": r.region,
            "tags": json.dumps(r.tags or {}),
        })
    session.client("s3").put_object(
        Bucket=bucket,
        Key=key,
        Body=buf.getvalue().encode("utf-8"),
        ContentType="text/csv",
    )
    logger.info("Checkpoint saved: s3://%s/%s (%d resources)", bucket, key, len(resources))


def diff_reports(
    previous: List[UntaggedResource],
    current: List[UntaggedResource],
) -> CheckpointDiff:
    """Compute the diff between a previous and current snapshot.

    Comparison is by ARN only.
    added   = in current but not in previous (newly untagged resources)
    removed = in previous but not in current (remediated or deleted resources)
    """
    prev_by_arn = {r.arn: r for r in previous}
    curr_by_arn = {r.arn: r for r in current}
    added = [r for arn, r in curr_by_arn.items() if arn not in prev_by_arn]
    removed = [r for arn, r in prev_by_arn.items() if arn not in curr_by_arn]
    return CheckpointDiff(added=added, removed=removed)
