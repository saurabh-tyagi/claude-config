workflow:
  auto_cancel:
    on_new_commit: interruptible
  rules:
    - if: '$CI_PIPELINE_SOURCE == "parent_pipeline"'

default:
  tags:
    - generic
    - micro

stages:
  - build-test
  - deploy

.prod:
  rules:
    - if: '$CI_COMMIT_BRANCH == $CI_DEFAULT_BRANCH'

test:
  image: python:3.11
  stage: build-test
  script:
    - cd lambda/untagged-reporter
    - python --version ; pip --version  # For debugging
    - pip install -r test/requirements.txt
    - pytest --junitxml=report.xml
  artifacts:
    reports:
      junit: lambda/untagged-reporter/report.xml

build-sam:
  image: public.ecr.aws/sam/build-python3.11:latest
  stage: build-test
  script:
    - cd lambda/untagged-reporter
    - sam build --config-env ci
  artifacts:
    expire_in: 1 week
    paths:
      - lambda/untagged-reporter/.aws-sam

.deploy-sam:
  stage: deploy
  image: public.ecr.aws/sam/build-python3.11:latest
  variables:
    ENV: datalake
    ASSUME_ROLE: "TRUE"
    AWS_DEFAULT_REGION: "eu-west-1"
  script:
    - cd lambda/untagged-reporter
    - sam deploy --no-fail-on-empty-changeset --config-env ${SAM_ENV}
  dependencies: [build-sam]

deploy-sam-dev:
  variables:
    SAM_ENV: dev
  environment:
    name: dev-sam
  extends:
    - .deploy-sam
  when: manual
  allow_failure: false

deploy-sam-prod:
  variables:
    SAM_ENV: prod
  environment:
    name: prod-sam
  extends:
    - .deploy-sam
    - .prod
