def _extract_resource_name(arn: str) -> str:
    """Extract a human-readable name from an ARN."""
    parts = arn.split(":")
    if len(parts) < 6:
        return arn
    resource_part = ":".join(parts[5:])
    # arn:aws:service:region:account:type/name       -> name (or team/name for nested paths)
    # arn:aws:ecr:...:repository/team/app            -> team/app (full path, not just last segment)
    if "/" in resource_part:
        return resource_part.split("/", 1)[1]
    # arn:aws:secretsmanager:...:secret:my-secret    -> my-secret (strip type prefix)
    # arn:aws:rds:...:db:my-database                 -> my-database
    if ":" in resource_part:
        return resource_part.split(":", 1)[1]
    # arn:aws:sqs:...:my-queue  or  arn:aws:s3:::my-bucket  -> my-queue / my-bucket
    return resource_part


# Services whose ARNs carry a bare resource name with no type prefix in parts[5].
# Example: arn:aws:sqs:eu-west-1:123456789012:my-queue  (parts[5] = "my-queue")
_BARE_RESOURCE_SERVICES = {"sqs": "sqs:queue", "sns": "sns:topic"}


def _extract_resource_type(arn: str) -> str:
    """Extract a normalised resource type string from an ARN.

    Format: service[:subtype]  e.g. 'ec2:instance', 's3:bucket', 'glue:job'

    Handles three ARN shapes:
      - S3:                                  arn:aws:s3:::bucket → "s3:bucket"
      - Bare name (SQS, SNS):                arn:aws:sqs:r:a:queue → "sqs:queue"
      - Standard  (type/name or type:name):  arn:aws:ec2:r:a:instance/id → "ec2:instance"
    """
    parts = arn.split(":")
    if len(parts) < 3:
        return "unknown"
    service = parts[2]
    # S3 is the only service with the ARN shape arn:aws:s3:::bucket
    if service == "s3":
        return "s3:bucket"
    # Services where parts[5] is a bare resource name, not a type prefix
    if service in _BARE_RESOURCE_SERVICES:
        return _BARE_RESOURCE_SERVICES[service]
    # Standard: parts[5] is "type/name", "type:name", or just "type"
    if len(parts) > 5 and parts[5]:
        sub = parts[5].split("/", 1)[0].split(":", 1)[0]
        return f"{service}:{sub}"
    return service


def _build_filter_string(required_tag: Optional[str]) -> str:
    """Build a Resource Explorer FilterString for a single tag key.

    Uses `resourcetype.supports:tags` to restrict to taggable resources server-side.
    Resource Explorer ANDs all space-separated terms, so multiple `resourcetype:` terms
    in one FilterString would match nothing (a resource can only have one type).
    Type filtering is therefore applied client-side in _run_query.

    scan_untagged_resources runs one query per required tag and unions results,
    giving all resources missing at least one required tag.
    """
    parts = [f"-tag.key:{required_tag}"] if required_tag else []
    parts.append("resourcetype.supports:tags")
    parts.append(f"region:{_REGION}")
    return " ".join(parts)


def _run_query(
    client,
    filter_string: str,
    excluded_resource_types: AbstractSet[str],
) -> Dict[str, UntaggedResource]:
    """Execute a single Resource Explorer list_resources query.

    Returns a dict of ARN -> UntaggedResource, dropping types in excluded_resource_types.
    """
    results: Dict[str, UntaggedResource] = {}
    paginator = client.get_paginator("list_resources")
    for page in paginator.paginate(Filters={"FilterString": filter_string}):
        for resource in page.get("Resources", []):
            arn = resource["Arn"]
            resource_type = resource.get("ResourceType") or _extract_resource_type(arn)
            if resource_type in excluded_resource_types:
                continue

            region = resource.get("Region", "")
            tags = {}
            for prop in resource.get("Properties", []):
                if prop.get("Name") == "tags":
                    try:
                        tags = {
                            t["Key"]: t["Value"]
                            for t in (prop.get("Data") or [])
                        }
                    except (TypeError, KeyError):
                        pass

            results[arn] = UntaggedResource(
                arn=arn,
                resource_type=resource_type,
                region=region,
                name=_extract_resource_name(arn),
                tags=tags,
            )
    return results


def scan_untagged_resources(
    session: boto3.Session,
    required_tags: Optional[List[str]] = None,
    excluded_resource_types: AbstractSet[str] = _DEFAULT_EXCLUDED_RESOURCE_TYPES,
) -> List[UntaggedResource]:
    """Scan eu-west-1 for resources missing required tags using AWS Resource Explorer.

    Runs one list_resources query per required tag and unions results by ARN.
    This ensures resources missing at least one required tag are returned, even
    if they have some of the other required tags. Type filtering is applied
    client-side after the API call (Resource Explorer ANDs all FilterString terms,
    so multiple resourcetype: terms would match nothing).

    New AWS service types not in excluded_resource_types pass through automatically,
    so the scanner adapts as AWS introduces new taggable resource types.

    Args:
        session: boto3 Session (credentials / profile already configured).
        required_tags: Tag keys every resource must have. Resources missing at
            least one of these are returned. If empty or None, all non-excluded
            taggable resources are returned.
        excluded_resource_types: Resource types to drop. Defaults to
            _DEFAULT_EXCLUDED_RESOURCE_TYPES (free/near-free AWS primitives).

    Returns:
        List of UntaggedResource objects (deduplicated by ARN, sorted by type and name).
    """
    tags_to_query: List[Optional[str]] = list(required_tags) if required_tags else [None]
    merged: Dict[str, UntaggedResource] = {}

    try:
        client = session.client("resource-explorer-2", region_name=_REGION)
        for tag in tags_to_query:
            filter_string = _build_filter_string(tag)
            logger.info("Resource Explorer filter (tag=%s): %s", tag, filter_string)
            merged.update(_run_query(client, filter_string, excluded_resource_types))

    except ClientError as exc:
        code = exc.response["Error"]["Code"]
        logger.error("Resource Explorer scan failed — %s: %s", code, exc)
        raise
    except Exception as exc:
        logger.error("Resource Explorer scan failed — unexpected error: %s", exc)
        raise

    untagged = sorted(merged.values(), key=lambda r: (r.resource_type, r.name))
    logger.info("Total resources found: %d", len(untagged))
    return untagged
